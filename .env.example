# Target
TARGET_URL=https://chat.z.ai
MODEL_NAME=GLM-5.1

# Server
HOST=0.0.0.0
PORT=8000
API_KEY=sk-web2api-placeholder

# DSML tool calling
DSML_ENABLED=true

# ── Captcha ──────────────────────────────────────────────────────────
# From HAR: captcha_verify_param in the POST body
# This expires after some time; regenerate by exporting a fresh HAR
CAPTCHA_VERIFY_PARAM=

# ── Signature (choose one) ───────────────────────────────────────────
# Option A: Static signature from HAR (query params must match exactly)
X_SIGNATURE=

# Option B: Auto-compute (requires knowing the HMAC secret key)
SIGNATURE_SECRET=

# ── Query string ─────────────────────────────────────────────────────
# Full query string from the HAR chat entry URL (everything after ?)
QUERY_STRING=

# ── Static headers (JSON) ────────────────────────────────────────────
# Headers from the HAR request (except Content-Length)
STATIC_HEADERS={"Content-Type":"application/json","Origin":"https://chat.z.ai","x-fe-version":"prod-fe-1.1.37","x-region":"overseas"}

# ── User info ────────────────────────────────────────────────────────
USER_NAME=
USER_LANGUAGE=zh-CN
CHAT_ID=
